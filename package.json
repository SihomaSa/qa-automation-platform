{
  "name": "qa-automation-platform",
  "version": "1.0.0",
  "description": "Full-stack QA automation framework — Playwright + TypeScript + Cucumber BDD",
  "scripts": {
    "test:e2e": "cucumber-js --config cucumber.config.cjs --profile e2e",
    "test:api": "cucumber-js --config cucumber.config.cjs --profile api",
    "test:all": "cucumber-js --config cucumber.config.cjs --profile all",
    "test:smoke": "cucumber-js --config cucumber.config.cjs --profile all --tags @smoke",
    "test:regression": "cucumber-js --config cucumber.config.cjs --profile all --tags @regression",
    "report": "allure generate allure-results --clean -o allure-report && allure open allure-report",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "axios": "^1.6.7",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.41.2",
    "@types/node": "^20.11.16",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "allure-commandline": "^2.38.1",
    "allure-cucumberjs": "^3.7.1",
    "allure-playwright": "^2.15.1",
    "dotenv": "^16.4.1",
    "eslint": "^8.56.0",
    "playwright": "^1.41.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3"
  }
}
